---
import Layout from '../layouts/Layout.astro';
import Home from '../components/HOME/Home.astro';
import About from '../components/ABOUT/About.astro';
import Rates from '../components/RATES/Rates.astro';
import Contact from '../components/CONTACT/Contact.astro';
import StudentPortal from '../components/STUDENT PORTAL/StudentPortal.astro';
---

<Layout>
  <Home/>
  <About/>
  <Rates/>
  <Contact/>
  <StudentPortal/>
</Layout>

<style>
</style>

<script>
  const header = document.querySelector<HTMLElement>('#site-header');

  if (!header) {
    throw new Error('Expected #site-header to exist.');
  }

  function updateHeaderHeight(header: HTMLElement) {
    document.documentElement.style.setProperty(
      '--header-height',
      `${header.offsetHeight}px`
    );
  }

  updateHeaderHeight(header);

  const observer = new ResizeObserver(() => {
    updateHeaderHeight(header);
  });

  observer.observe(header);
</script>