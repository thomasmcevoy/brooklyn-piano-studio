---
const {
  columns,
  gap,
  alignItems,
  variant = "",
  class: className = ""
} = Astro.props;
---

<div
  class={`grid ${variant} ${className}`}
  style={`
    --columns: ${columns};
    --gap: ${gap};
    --align-items: ${alignItems}
  `}
>
  <slot />
</div>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(var(--columns), 1fr);
    gap: var(--gap);
    align-items: var(--align-items);
  }

  .grid.footer {
    grid-template-columns: 1fr 1fr 1fr;
  }

  @media (max-width: 700px) {
    .grid {
      grid-template-columns: 1fr;
    }

    .grid.footer {
      grid-template-columns: 1fr 1fr;
    }

    .grid.footer > :global(.blurb) {
      grid-column: 1;
      grid-row: 2;
    }

    .grid.footer > :global(nav) {
      grid-column: 2;
      grid-row: 2;
    }

    .grid.footer > :global(.footer-cta) {
      grid-column: 1 / -1;
      grid-row: 1;
      justify-self: center;
    }
  }
</style>