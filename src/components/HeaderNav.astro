---
const currentPath = Astro.url.pathname;
---

<nav>
  <ul>
    <li><a href="/about" class={currentPath.startsWith("/about") ? "active" : ""}>About</a></li>
    <li><a href="/rates" class={currentPath.startsWith("/rates") ? "active" : ""}>Rates</a></li>
    <li><a href="/contact" class={currentPath.startsWith("/contact") ? "active" : ""}>Contact</a></li>
    <li><a href="/resources" class={currentPath.startsWith("/resources") ? "active" : ""}>Resources</a></li>
  </ul>
</nav>

<style>
nav ul {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
  margin: 0;
  padding: 0;
}

nav li {
  margin: 0;
}

nav li a:not(.active):hover {
  color: var(--gold);
}

nav a.active {
  cursor: default;
}

nav a.active::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: .25rem;
  width: 100%;
  height: .075em;
  background: var(--gold);
}
</style>