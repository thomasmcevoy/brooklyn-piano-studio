---
import Container from '../components/Container.astro';
import Grid from '../components/Grid.astro';
import Card from '../components/Card.astro';
---

<section class="lesson-pricing">
  <Container size="wide">

    <h2>Lesson Pricing</h2>
    
    <div class="pricing-cards">
      <Grid columns="3" gap="3.5rem">

        <Card>
          <h3>In Studio</h3>
          <h4>Single private lesson:</h4>
          <ul>
            <li>30 mins: $85</li>
            <li>45 mins: $130</li>
            <li>1 hour: $175</li>
          </ul>
          <h4>Monthly rates:</h4>
          <ul>
            <li>4 weekly x 30 mins: $75 per lesson</li>
            <li>4 weekly x 45 mins: $120 per lesson</li>
            <li>4 weekly x 1 hour: $160 per lesson</li>
          </ul>
        </Card>

        <Card>
          <h3>Online</h3>
          <h4>Single private lesson:</h4>
          <ul>
            <li>30 mins: $80</li>
            <li>45 mins: $125</li>
            <li>1 hour: $165</li>
          </ul>
          <h4>Monthly rates:</h4>
          <ul>
            <li>4 weekly x 30 mins: $70 per lesson</li>
            <li>4 weekly x 45 mins: $115 per lesson</li>
            <li>4 weekly x 1 hour: $150 per lesson</li>
          </ul>
        </Card>
          
        <Card>
          <h3>In Your Home</h3>
          <p>Rates for lessons in your home are determined based on distance and availability.</p>
        </Card>
        
      </Grid>
    </div>

    <p class="sliding-scale"><small>We don't want cost to be a barrier to access for people with financial constraints. If this applies to you, please inquire about our sliding scale.</small></p>
  
  </Container>
</section>

<style>
.lesson-pricing {
  padding-block: var(--section-padding-block);
  background: var(--walnut);
}

.lesson-pricing h2 {
  text-align: center;
  margin-top: 1rem;
  padding-bottom: .25rem;
  border-bottom: .05em var(--gold) solid;
}

.pricing-cards {
  padding-block: 1.5rem;
}

h2 {
  color: var(--parchment);
}

.sliding-scale {
  text-align: center;
  font-style: italic;
  color: var(--dark-parchment);
  position: relative;
  top: 3.5rem;
}
</style>