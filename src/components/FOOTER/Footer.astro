---
import Container from '../UI/Container.astro';
import Wordmark from '../UI/Wordmark.astro';
import Grid from '../UI/Grid.astro';
import Cta from '../UI/Cta.astro';
import Nav from './FooterNav.astro';
import Blurb from './FooterBlurb.astro';

const { showCta } = Astro.props;
---

<footer>
  <Container size="medium-flexible">
    
    <div class="wordmark-container">
      <Wordmark text="Brooklyn Piano Studio" />
    </div>

    <Grid variant="footer">
      
      <Blurb />
      <Nav />
      <Cta 
        text="Ready to get started?"
        buttonText="BOOK A LESSON"
        variant="footer"
      />
      
    </Grid>

    <p class="copyright"><small>All content &copy; 2026 Brooklyn Piano Studio</small></p>
  </Container>
</footer>

<style>
footer {
  --footer-text: #5F6470;
  --footer-text-2: #626771;
  --footer-text-3: #7D828C;
  --footer-text-bright: rgb(194, 199, 208);
  
  padding-top: var(--section-spacing-md);
  padding-bottom: var(--section-spacing-sm);
  background-color: var(--site-background-color);
}

.wordmark-container {
  position: relative;
  padding-bottom: .375rem;
  border-bottom: 1px solid rgba(232, 221, 207, 0.2);
  text-align: center;
  color: var(--footer-text);
  font-size: 1.5rem;
  letter-spacing: .1rem ;
  opacity: .8;
}

.copyright {
  margin-top: var(--section-spacing-xs);
  text-align: center;
  font-style: italic;
  color: var(--footer-text-3);
  opacity: 0.7;
}
</style>