---
import Button from './Button.astro';
import { Image } from "astro:assets";
import heroImage from "../assets/hero2.jpg";
---

<section class="hero">
  <Image
    src={heroImage}
    alt="Image of student playing the piano"
    class="hero-image"
  />

  <div class="hero-content">
    <h1>Private piano lessons in&nbsp;Brooklyn</h1>
    <p>Individualized instruction for all ages and skill levels, tailored to your goals.</p>
    <Button text="Schedule your first lesson" variant="hero"/>
  </div>
</section>

<style>
.hero {
  position: relative;
  min-height: 100dvh;
  display: grid;
  place-items: center;
  overflow: hidden;
  margin: 0;
}

.hero::before {
  content: "";
  position: absolute;
  inset: 0;
  background: rgb(0 0 0 / 0.35);
  z-index: 1;
}

.hero-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.hero-content {
  position: relative;
  z-index: 1;
  text-align: center;
}

.hero-content p {
  font-style: italic;
}

.hero-content a,
.hero-content p,
.hero-content h1 {
  color: var(--parchment);
}
</style>